
# ═══════════════════════════════════════════════════
# CALCMASTER ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# The app works fully WITHOUT these — ads/analytics
# simply remain disabled until configured.
# ═══════════════════════════════════════════════════

# ── GOOGLE ADMOB ──
EXPO_PUBLIC_ADMOB_ANDROID_APP_ID=
EXPO_PUBLIC_ADMOB_IOS_APP_ID=
EXPO_PUBLIC_ADMOB_BANNER_ID=
EXPO_PUBLIC_ADMOB_INTERSTITIAL_ID=
EXPO_PUBLIC_ADMOB_REWARDED_ID=
EXPO_PUBLIC_ADMOB_APP_OPEN_ID=

# ── FIREBASE ANALYTICS ──
EXPO_PUBLIC_FIREBASE_ENABLED=false

# ── FEATURE FLAGS ──
EXPO_PUBLIC_ADS_ENABLED=false
EXPO_PUBLIC_ANALYTICS_ENABLED=false
